📄 3. detections/*.kql
privilege_escalation.kql
Writing

SecurityEvent
| where EventID == 4672
| summarize EventCount = count() by Account, Computer, bin(TimeGenerated, 5m)
| where EventCount > 0

brute_force.kql
Writing

SecurityEvent
| where EventID == 4625
| summarize FailedLogins = count() by Account, bin(TimeGenerated, 5m)
| where FailedLogins >= 5

powershell_detection.kql
Writing

SecurityEvent
| where Process has "powershell"
| where CommandLine contains "-enc"
or CommandLine contains "Invoke-Expression"

account_creation.kql
Writing

SecurityEvent
| where EventID == 4720
| summarize NewAccounts = count() by Account, bin(TimeGenerated, 10m)
| where NewAccounts > 0

